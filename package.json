{
  "name": "roam-platform",
  "private": true,
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev": "pnpm --filter @roam/fleet dev",
    "dev:customer": "pnpm --filter @roam/dash-customer dev",
    "dev:merchant": "pnpm --filter @roam/dash-merchant dev",
    "dev:all": "pnpm --parallel -r dev",
    "dev:local-stack:free-ports": "npx --yes kill-port 3000 3001 3002 5174 5175 5180",
    "dev:local-stack": "pnpm --parallel --filter @roam/fleet --filter @roam/admin --filter @roam/driver --filter @roam/dash-customer --filter @roam/dash-merchant --filter @roam/rides-passenger run dev",
    "build": "pnpm -r build",
    "build:fleet": "pnpm --filter @roam/fleet build",
    "build:customer": "pnpm --filter @roam/dash-customer build",
    "build:merchant": "pnpm --filter @roam/dash-merchant build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "deploy:edge": "npx supabase functions deploy make-server-37f42386 --use-api --project-ref csfllzzastacofsvcdsc",
    "deploy:delivery": "npx supabase functions deploy delivery --use-api --project-ref csfllzzastacofsvcdsc",
    "deploy:payments": "npx supabase functions deploy payments --use-api --project-ref csfllzzastacofsvcdsc",
    "dev:rides-passenger": "pnpm --filter @roam/rides-passenger dev",
    "build:rides-passenger": "pnpm --filter @roam/rides-passenger build",
    "deploy:rides": "npx supabase functions deploy rides --use-api --project-ref csfllzzastacofsvcdsc"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}
