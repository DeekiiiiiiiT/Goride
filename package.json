{
  "name": "roam-platform",
  "private": true,
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "test:e2e:toll": "node scripts/e2e/toll-reconciliation-smoke.mjs",
    "dev": "pnpm --filter @roam/fleet dev",
    "dev:enterprise": "pnpm --filter @roam/enterprise dev",
    "build:enterprise": "pnpm --filter @roam/enterprise build",
    "dev:customer": "pnpm --filter @roam/dash-customer dev",
    "dev:merchant": "pnpm --filter @roam/dash-merchant dev",
    "dev:courier": "pnpm --filter @roam/dash-courier dev",
    "dev:all": "pnpm --parallel -r dev",
    "dev:local-stack:free-ports": "npx --yes kill-port 3000 3001 3002 5174 5175 5180",
    "dev:local-stack": "pnpm --parallel --filter @roam/fleet --filter @roam/admin --filter @roam/driver --filter @roam/dash-customer --filter @roam/dash-merchant --filter @roam/rides-passenger run dev",
    "build": "pnpm -r build",
    "build:fleet": "pnpm --filter @roam/fleet build",
    "build:customer": "pnpm --filter @roam/dash-customer build",
    "build:merchant": "pnpm --filter @roam/dash-merchant build",
    "build:courier": "pnpm --filter @roam/dash-courier build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "deploy:edge": "npx supabase functions deploy make-server-37f42386 --use-api --project-ref csfllzzastacofsvcdsc",
    "deploy:delivery": "npx supabase functions deploy delivery --use-api --project-ref csfllzzastacofsvcdsc",
    "deploy:payments": "npx supabase functions deploy payments --use-api --project-ref csfllzzastacofsvcdsc",
    "dev:rides-passenger": "pnpm --filter @roam/rides-passenger dev",
    "build:rides-passenger": "pnpm --filter @roam/rides-passenger build",
    "dev:haul": "pnpm --filter @roam/haul dev",
    "build:haul": "pnpm --filter @roam/haul build",
    "cap:driver:sync": "pnpm --filter @roam/driver cap:sync",
    "cap:driver:release": "pnpm --filter @roam/driver cap:release",
    "cap:driver:aab": "pnpm --filter @roam/driver cap:aab",
    "cap:driver:android": "pnpm --filter @roam/driver cap:open:android",
    "cap:rides:sync": "pnpm --filter @roam/rides-passenger cap:sync",
    "cap:rides:release": "pnpm --filter @roam/rides-passenger cap:release",
    "cap:rides:aab": "pnpm --filter @roam/rides-passenger cap:aab",
    "cap:rides:android": "pnpm --filter @roam/rides-passenger cap:open:android",
    "deploy:rides": "npx supabase functions deploy rides --use-api --project-ref csfllzzastacofsvcdsc",
    "deploy:haul": "npx supabase functions deploy haul --use-api --project-ref csfllzzastacofsvcdsc",
    "deploy:toll-brain": "npx supabase functions deploy toll-brain --use-api --project-ref csfllzzastacofsvcdsc",
    "deploy:fuel-brain": "npx supabase functions deploy fuel-brain --use-api --project-ref csfllzzastacofsvcdsc"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  },
  "workspaces": ["apps/*", "packages/*", "services/*"]
}
