{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@roam/types": ["../../packages/types/src"],
      "@roam/types/*": ["../../packages/types/src/*"],
      "@roam/ui": ["../../packages/ui/src"],
      "@roam/ui/*": ["../../packages/ui/src/*"],
      "@roam/api-client": ["../../packages/api-client/src"],
      "@roam/api-client/*": ["../../packages/api-client/src/*"],
      "@roam/auth-client": ["../../packages/auth-client/src"],
      "@roam/auth-client/*": ["../../packages/auth-client/src/*"],
      "@roam/hauler-dispatch": ["../../packages/hauler-dispatch/src"],
      "@roam/hauler-dispatch/*": ["../../packages/hauler-dispatch/src/*"],
      "@roam/admin-core": ["../../packages/admin-core/src"],
      "@roam/admin-core/*": ["../../packages/admin-core/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
