{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@fleet/*": ["../fleet/src/*"],
      "@/*": ["../fleet/src/*"],
      "@roam/api-client": ["../../packages/api-client/src"],
      "@roam/api-client/*": ["../../packages/api-client/src/*"],
      "@roam/auth-client": ["../../packages/auth-client/src"],
      "@roam/auth-client/*": ["../../packages/auth-client/src/*"],
      "@roam/business-config": ["../../packages/business-config/src"],
      "@roam/business-config/*": ["../../packages/business-config/src/*"],
      "@roam/types": ["../../packages/types/src"],
      "@roam/types/*": ["../../packages/types/src/*"],
      "@roam/ui": ["../../packages/ui/src"],
      "@roam/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src"]
}
