{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && npm install -g pnpm@9.15.4 && pnpm install --no-frozen-lockfile --ignore-scripts && pnpm rebuild esbuild @tailwindcss/oxide",
  "buildCommand": "cd ../.. && pnpm --filter @roam/rides-passenger build",
  "outputDirectory": "dist",
  "framework": null,
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "/" },
    { "source": "/((?!\\.well-known/).*)", "destination": "/" }
  ]
}
