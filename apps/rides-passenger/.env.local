# Enable "Get rider's location" on Book for Someone Else (local / test builds).
VITE_PICKUP_LOCATION_REQUEST=1

# Enable Roam Connections (Pending hub, friend requests, incoming banner).
VITE_ROAM_CONNECTIONS=1

# Enable Activity bottom-nav tab (client-only; /activity works without this).
VITE_ACTIVITY_TAB=1

# Cash settlement: driver collect-payment flow + rider cash trip summary + wallet journal.
VITE_CASH_SETTLEMENT=1
VITE_CASH_SETTLEMENT_V2=1
VITE_CASH_SETTLEMENT_SWITCH_TO_CARD=1
